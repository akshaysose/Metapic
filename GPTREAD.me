### Face Service Logic (`face-service/app/main.py`)
FastAPI service that accepts images and returns embeddings.

```python
from fastapi import FastAPI, File, UploadFile, HTTPException
from fastapi.responses import JSONResponse
import uvicorn
from .model_manager import ModelManager
from typing import List
from pydantic import BaseModel

app = FastAPI(title='KwikPic Face Service (InsightFace)')

model_mgr = ModelManager()

class UrlsRequest(BaseModel):
    urls: List[str]

@app.post("/embed")
async def embed_file(file: UploadFile = File(...)):
    content = await file.read()
    emb = model_mgr.embed_bytes(content)
    return JSONResponse({"embedding": emb.tolist()})

@app.post("/embed-urls")
async def embed_urls(req: UrlsRequest):
    res = []
    for url in req.urls:
        emb = model_mgr.embed_url(url)
        res.append({"url": url, "embedding": emb.tolist()})
    return {"items": res}

@app.get("/health")
async def health():
    return {"ok": True}

# For local debug:
if __name__ == "__main__":
    uvicorn.run("app.main:app", host="0.0.0.0", port=8000, reload=True)
```

### Face Analysis Logic (`face-service/app/model_manager.py`)
Uses InsightFace to detect faces and compute embeddings.

```python
import numpy as np
import cv2
import insightface
from insightface.app import FaceAnalysis
import tempfile
import requests
from io import BytesIO

class ModelManager:
    """
    Loads InsightFace FaceAnalysis (antelope) and exposes embedding helpers.
    """

    def __init__(self):
        # Load antelopev2 / arcface model
        self.app = FaceAnalysis(name='antelopev2', allowed_modules=['detection', 'recognition'])
        self.app.prepare(ctx_id=0 if self._has_gpu() else -1)

    def _has_gpu(self):
        try:
            import mxnet as mx
            return mx.context.num_gpus() > 0
        except Exception:
            return False

    def _read_bytes(self, bts):
        arr = np.frombuffer(bts, np.uint8)
        img = cv2.imdecode(arr, cv2.IMREAD_COLOR)
        return img

    def embed_bytes(self, bts):
        img = self._read_bytes(bts)
        if img is None:
            raise ValueError("Invalid image")
        faces = self.app.get(img)
        if not faces:
            return np.zeros(512, dtype=float)
        # choose the largest face
        face = max(faces, key=lambda f: f.bbox_area)
        emb = face.embedding
        return np.array(emb, dtype=float)

    def embed_url(self, url):
        r = requests.get(url, timeout=20)
        return self.embed_bytes(r.content)
```

